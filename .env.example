# Link2Pod environment configuration
# Copy this file to .env and customize paths for your machine

# OpenRouter API key (required for LLM processing)
# OPENROUTER_API_KEY=your_api_key_here

# Kokoro model paths (optional - defaults to link2pod directory)
KOKORO_MODEL_PATH=/home/openclaw/.openclaw/workspace/models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=/home/openclaw/.openclaw/workspace/models/voices-v1.0.bin
